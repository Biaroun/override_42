#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <fcntl.h>
#include <unistd.h>

void log_wrapper(FILE *log, char *msg, char *file) {
    char buffer[256];
    strcpy(buffer, msg);
    snprintf(buffer + strlen(buffer), 255 - strlen(buffer), file);
    fprintf(log, "LOG: %s\n", buffer);
}

int main(int argc, char **argv) {
    FILE *log_fp;
    FILE *source_fp;
    int dest_fd;
    char c;
    char dest_path[100];

    if (argc != 2) {
        printf("Usage: %s filename\n", argv[0]);
    }

    log_fp = fopen("./backups/.log", "w");
    if (!log_fp) {
        printf("ERROR: Failed to open %s\n", "./backups/.log");
        exit(1);
    }

    log_wrapper(log_fp, "Starting back up: ", argv[1]);

    source_fp = fopen(argv[1], "r");
    if (!source_fp) {
        printf("ERROR: Failed to open %s\n", argv[1]);
        exit(1);
    }

    strcpy(dest_path, "./backups/");
    strncat(dest_path, argv[1], 99 - strlen(dest_path));

    dest_fd = open(dest_path, O_WRONLY | O_CREAT | O_EXCL, 0660);
    if (dest_fd < 0) {
        printf("ERROR: Failed to open %s%s\n", "./backups/", argv[1]);
        exit(1);
    }

    while ((c = fgetc(source_fp)) != (char)EOF) {
        write(dest_fd, &c, 1);
    }

    log_wrapper(log_fp, "Finished back up ", argv[1]);

    fclose(source_fp);
    close(dest_fd);
    return 0;
}
